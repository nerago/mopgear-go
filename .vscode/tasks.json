{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "go",
			"label": "go: build optimised",
			"command": "build",
			"args": [
				"-o", "main.exe",
				"-v",
				"-pgo=./main.pgo",
				"./main"
			],
			"presentation": {
				"reveal": "silent"
			},
			"problemMatcher": [
				"$go"
			],
			"group": {
				"kind": "build",
			}
		},

		{
			"type": "shell",
			"label": "clean optimised",
			"command": "rm main.exe",
			"presentation": {
				"reveal": "silent"
			},
			"hide": true
		}
	]
}