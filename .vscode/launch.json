{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Gearing Debug",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "./nerago-gearing/main",
            "buildFlags": "-tags=with_db",
        },

        {
            "name": "Launch Gearing Optimised",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "program": "main.exe",
            "preLaunchTask": "Build Gearing Optimised"
        },

        {
            "name": "Launch test function",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}",
            "args": ["-v"]
        }
    ]
}