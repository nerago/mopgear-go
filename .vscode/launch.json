{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Package Debug",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "main"
        },

        {
            "name": "Launch Package Optimised",
            "type": "go",
            "request": "launch",
            "mode": "exec",
            "program": "main.exe",
            "preLaunchTask": "go: build optimised"
            // "postDebugTask": "clean optimised"
        },

        {
            "name": "Launch test function",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}",
            "args": ["-v"]
        }
    ]
}